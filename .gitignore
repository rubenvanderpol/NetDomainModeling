# .gitignore for .NET projects
# Build results
[Bb]in/
[Oo]bj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider project files
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# DotCover
*.dotCover

# NCrunch
*.ncrunch*
.*crunch*.local.xml

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
!**/packages/build/
!**/packages/repositories.config

# Windows image file caches
Thumbs.db
desktop.ini

# Windows Installer files
*.cab
*.msi
*.msm
*.msp

# Windows shortcuts
*.lnk

# Logs
*.log

# Others
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Local history for JetBrains IDEs
.localhistory/

# Backup & report files from converting an old project file
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.rsuser
*- [Bb]ackup.rdl

# Publish Web Output
*.Publish.xml
*.pubxml
*.publishproj

# Azure Stream Analytics local run output
ASALocalRun/

# Node.js Tools for Visual Studio
node_modules/

# Yarn
.yarn/
.pnp.*

# dotenv environment variables file
.env
.env.*

# Domain model explorer / feature editor persisted files (example app working directory)
DomainModeling.Example/metadata/
DomainModeling.Example/features/
