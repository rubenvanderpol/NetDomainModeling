{
  "name": "domainmodeling-workbench-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:explorer",
    "typecheck": "tsc -b",
