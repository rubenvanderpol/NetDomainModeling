{
  "name": "diagram-poc",
  "version": "0.1.0",
  "private": true,
  "description": "Electron + TypeScript POC: configurable graph diagram (generic node/edge kinds)",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --target=node20 --format=esm --outdir=dist/electron --external:electron",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^22.10.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "electron": "^33.2.0",
    "esbuild": "^0.24.0",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
